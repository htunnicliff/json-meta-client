{
  "name": "json-meta-client",
  "version": "0.1.0",
  "bugs": {
    "url": "https://github.com/htunnicliff/json-meta-client/issues"
  },
  "author": {
    "name": "Hunter Tunnicliff",
    "email": "hunter@tunnicliff.co"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/htunnicliff/json-meta-client.git"
  },
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./*": "./dist/*"
  },
  "scripts": {
    "build": "tsdown",
    "types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "spelling:check": "cspell .",
    "version": "pnpm run build && changeset version && pnpm install",
    "publish": "pnpm run build && pnpm publish --access public"
  },
  "dependencies": {
    "jmap-rfc-types": "^0.1.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "cspell": "10.0.1",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "tsdown": "0.22.7",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
