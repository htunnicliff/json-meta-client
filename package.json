{
  "name": "json-meta-client",
  "version": "0.1.1",
  "bugs": {
    "url": "https://github.com/htunnicliff/json-meta-client/issues"
  },
  "author": {
    "name": "Hunter Tunnicliff",
    "email": "hunter@tunnicliff.co"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/htunnicliff/json-meta-client.git"
  },
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./*": "./dist/*"
  },
  "scripts": {
    "build": "tsdown",
    "types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "spelling:check": "cspell .",
    "version": "pnpm run build && changeset version && pnpm install",
    "publish": "pnpm run build && pnpm publish --access public"
  },
  "dependencies": {
    "jmap-rfc-types": "^0.1.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "cspell": "10.0.1",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "tsdown": "0.22.7",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
